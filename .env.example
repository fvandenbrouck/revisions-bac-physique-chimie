# Créer le fichier réel à la racine du projet avec :
# echo 'ANTHROPIC_API_KEY=VOTRE_CLE_ANTHROPIC_ICI' > .env

ANTHROPIC_API_KEY=VOTRE_CLE_ANTHROPIC_ICI

# Sonnet le plus performant à date du pipeline.
CLAUDE_MODEL=claude-sonnet-4-6

# Plafond de sortie élevé pour limiter les réponses tronquées.
# Si l'API renvoie une erreur de plafond, baisser cette valeur selon le modèle/compte.
CLAUDE_MAX_TOKENS=64000
# Surcharges optionnelles par type d'appel :
# CLAUDE_MAX_TOKENS_PROGRAMME=64000
# CLAUDE_MAX_TOKENS_EXERCISE=64000
# CLAUDE_MAX_TOKENS_COURSE=64000
# CLAUDE_MAX_TOKENS_QUIZ=16000

CLAUDE_TEMPERATURE=0.1

# Chemin optionnel vers le programme officiel si tu ne le mets pas dans site/programme/Terminale PC.pdf
PROGRAMME_PDF_PATH=site/programme/Terminale PC.pdf

# Racine du site si différente
# BAC_SITE_ROOT=/chemin/vers/site

# Rendu des pages de sujets en PNG
PDF_RENDER_DPI=144
